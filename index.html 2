/* --- DESIGN SYSTEM & VARIÁVEIS --- */
:root {
    --primary: #c5a059; /* Dourado */
    --bg-dark: #121212;
    --text-light: #f4f4f4;
    --text-dark: #333;
    --radius: 8px;
    --spacing: 2rem;
    --transition: all 0.4s ease;
    --font-base: 16px;
}

/* --- MODO ALTO CONTRASTE --- */
body.high-contrast {
    --primary: #ffff00;
    --bg-dark: #000;
    --text-light: #fff;
    background-color: #000 !important;
}

* { margin: 0; padding: 0; box-sizing: border-box; }

body {
    font-family: 'Segoe UI', sans-serif;
    background-color: var(--bg-dark);
    color: var(--text-light);
    font-size: var(--font-base);
    line-height: 1.6;
    overflow-x: hidden;
}

.container {
    max-width: 1100px;
    margin: 0 auto;
    padding: var(--spacing);
}

/* --- GRID & LAYOUT --- */
/* Edite o grid-template-columns abaixo para mudar a quantidade de cards */
.grid-container {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 20px;
    margin-top: 1rem;
}

header {
    background: #000;
    padding: 1rem 0;
    position: sticky;
    top: 0;
    z-index: 100;
}

.nav-links {
    display: flex;
    list-style: none;
    gap: 15px;
}

.nav-links a {
    color: var(--text-light);
    text-decoration: none;
    font-weight: bold;
}

/* --- COMPONENTES --- */
.card {
    background: #1e1e1e;
    padding: 1.5rem;
    border-radius: var(--radius);
    border-bottom: 3px solid var(--primary);
    transition: var(--transition);
}

.card:hover { transform: translateY(-5px); }

/* Acordeão */
.accordion-header {
    width: 100%;
    padding: 1rem;
    background: #222;
    color: var(--primary);
    border: none;
    text-align: left;
    cursor: pointer;
    font-weight: bold;
    margin-bottom: 5px;
}

.accordion-content {
    display: none;
    padding: 1rem;
    background: #2a2a2a;
}

.active + .accordion-content { display: block; }

/* Carrossel Simples */
.carousel-wrapper { overflow: hidden; position: relative; }
.carousel { display: flex; transition: var(--transition); gap: 20px; }

/* --- ACESSIBILIDADE --- */
.accessibility-bar {
    background: var(--primary);
    padding: 5px;
    display: flex;
    justify-content: flex-end;
    gap: 10px;
}

/* --- ANIMAÇÕES (SCROLL REVEAL) --- */
.reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: var(--transition);
}

.reveal.visible {
    opacity: 1;
    transform: translateY(0);
}
